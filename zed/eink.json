{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "Eink",
  "author": "einkeink",
  "themes": [
    {
      "name": "Eink",
      "appearance": "light",
      "style": {
        "background": "#ffffff",
        "surface.background": "#f5f5f5",
        "elevated_surface.background": "#f0f0f0",
        "panel.background": "#f5f5f5",

        "text": "#000000",
        "text.muted": "#555555",
        "text.placeholder": "#888888",
        "text.disabled": "#aaaaaa",
        "text.accent": "#000000",

        "icon": "#333333",
        "icon.muted": "#777777",
        "icon.disabled": "#aaaaaa",
        "icon.accent": "#000000",

        "border": "#cccccc",
        "border.variant": "#dddddd",
        "border.focused": "#000000",
        "border.selected": "#000000",
        "border.disabled": "#e0e0e0",
        "border.transparent": "#00000000",

        "element.background": "#e8e8e8",
        "element.hover": "#dddddd",
        "element.active": "#cccccc",
        "element.selected": "#d0d0d0",
        "element.disabled": "#f0f0f0",

        "ghost_element.background": "#00000000",
        "ghost_element.hover": "#e8e8e8",
        "ghost_element.active": "#dddddd",
        "ghost_element.selected": "#e0e0e0",
        "ghost_element.disabled": "#00000000",

        "drop_target.background": "#e0e0e0",

        "editor.background": "#ffffff",
        "editor.foreground": "#000000",
        "editor.gutter.background": "#ffffff",
        "editor.line_number": "#aaaaaa",
        "editor.active_line_number": "#000000",
        "editor.active_line.background": "#f5f5f5",
        "editor.highlighted_line.background": "#eeeeee",
        "editor.invisible": "#cccccc",
        "editor.indent_guide": "#e0e0e0",
        "editor.indent_guide_active": "#aaaaaa",
        "editor.wrap_guide": "#e8e8e8",
        "editor.active_wrap_guide": "#cccccc",
        "editor.subheader.background": "#f0f0f0",
        "editor.document_highlight.read_background": "#cccccc",
        "editor.document_highlight.write_background": "#bbbbbb",

        "tab_bar.background": "#f0f0f0",
        "tab.active_background": "#ffffff",
        "tab.inactive_background": "#f0f0f0",

        "title_bar.background": "#f0f0f0",
        "title_bar.inactive_background": "#f5f5f5",
        "toolbar.background": "#ffffff",
        "status_bar.background": "#f0f0f0",

        "search.match_background": "#bbbbbb",

        "scrollbar.track.background": "#f5f5f5",
        "scrollbar.track.border": "#e8e8e8",
        "scrollbar.thumb.background": "#cccccc",
        "scrollbar.thumb.hover_background": "#aaaaaa",
        "scrollbar.thumb.border": "#cccccc",

        "panel.indent_guide": "#e0e0e0",
        "panel.indent_guide_hover": "#cccccc",
        "panel.indent_guide_active": "#aaaaaa",
        "panel.focused_border": "#000000",
        "pane.focused_border": "#000000",

        "error": "#000000",
        "error.background": "#e0e0e0",
        "error.border": "#999999",
        "warning": "#444444",
        "warning.background": "#eeeeee",
        "warning.border": "#bbbbbb",
        "success": "#333333",
        "success.background": "#eeeeee",
        "success.border": "#bbbbbb",
        "hint": "#777777",
        "hint.background": "#f5f5f5",
        "hint.border": "#dddddd",
        "info": "#555555",
        "info.background": "#f0f0f0",
        "info.border": "#cccccc",

        "predictive": "#999999",
        "predictive.background": "#f5f5f5",
        "predictive.border": "#e0e0e0",

        "hidden": "#aaaaaa",
        "hidden.background": "#f5f5f5",
        "hidden.border": "#e0e0e0",

        "created": "#333333",
        "created.background": "#eeeeee",
        "created.border": "#cccccc",
        "modified": "#555555",
        "modified.background": "#f0f0f0",
        "modified.border": "#cccccc",
        "deleted": "#222222",
        "deleted.background": "#e8e8e8",
        "deleted.border": "#bbbbbb",
        "renamed": "#666666",
        "renamed.background": "#f0f0f0",
        "renamed.border": "#cccccc",

        "conflict": "#333333",
        "conflict.background": "#e0e0e0",
        "conflict.border": "#999999",
        "unreachable": "#bbbbbb",
        "unreachable.background": "#f5f5f5",
        "unreachable.border": "#dddddd",

        "players": [
          {
            "cursor": "#000000",
            "background": "#000000",
            "selection": "#888888"
          }
        ],

        "syntax": {
          "attribute": { "color": "#333333" },
          "boolean": { "color": "#000000", "font_weight": 700 },
          "comment": { "color": "#888888", "font_style": "italic" },
          "comment.doc": { "color": "#777777", "font_style": "italic" },
          "constant": { "color": "#222222" },
          "constructor": { "color": "#222222" },
          "embedded": { "color": "#333333" },
          "emphasis": { "color": "#000000", "font_style": "italic" },
          "emphasis.strong": { "color": "#000000", "font_weight": 700 },
          "enum": { "color": "#333333" },
          "function": { "color": "#111111" },
          "function.method": { "color": "#111111" },
          "hint": { "color": "#888888" },
          "keyword": { "color": "#000000", "font_weight": 700 },
          "label": { "color": "#444444" },
          "link_text": { "color": "#333333" },
          "link_uri": { "color": "#555555" },
          "number": { "color": "#222222" },
          "operator": { "color": "#333333" },
          "predictive": { "color": "#999999" },
          "preproc": { "color": "#444444" },
          "primary": { "color": "#000000" },
          "property": { "color": "#333333" },
          "punctuation": { "color": "#555555" },
          "punctuation.bracket": { "color": "#666666" },
          "punctuation.delimiter": { "color": "#555555" },
          "punctuation.list_marker": { "color": "#444444" },
          "punctuation.special": { "color": "#444444" },
          "string": { "color": "#333333" },
          "string.escape": { "color": "#222222" },
          "string.regex": { "color": "#444444" },
          "string.special": { "color": "#333333" },
          "string.special.symbol": { "color": "#222222" },
          "tag": { "color": "#222222" },
          "text.literal": { "color": "#333333" },
          "title": { "color": "#000000", "font_weight": 700 },
          "type": { "color": "#222222" },
          "variable": { "color": "#111111" },
          "variable.special": { "color": "#000000" },
          "variant": { "color": "#333333" }
        },

        "terminal.background": "#ffffff",
        "terminal.foreground": "#000000",
        "terminal.bright_foreground": "#000000",
        "terminal.dim_foreground": "#666666",
        "terminal.ansi.black": "#000000",
        "terminal.ansi.red": "#222222",
        "terminal.ansi.green": "#333333",
        "terminal.ansi.yellow": "#555555",
        "terminal.ansi.blue": "#444444",
        "terminal.ansi.magenta": "#555555",
        "terminal.ansi.cyan": "#333333",
        "terminal.ansi.white": "#cccccc",
        "terminal.ansi.bright_black": "#888888",
        "terminal.ansi.bright_red": "#2a2a2a",
        "terminal.ansi.bright_green": "#444444",
        "terminal.ansi.bright_yellow": "#666666",
        "terminal.ansi.bright_blue": "#555555",
        "terminal.ansi.bright_magenta": "#777777",
        "terminal.ansi.bright_cyan": "#444444",
        "terminal.ansi.bright_white": "#e0e0e0"
      }
    }
  ]
}
